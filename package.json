{
  "name": "scavio",
  "version": "0.2.1",
  "description": "TypeScript SDK for the Scavio Search API — real-time Google, Amazon, Walmart, YouTube, Reddit, TikTok, and Instagram data",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "search",
    "api",
    "ai",
    "web-search",
    "google-search",
    "amazon",
    "walmart",
    "youtube",
    "reddit",
    "tiktok",
    "serp",
    "scraping",
    "instagram",
    "tavily-alternative",
    "serpapi-alternative"
  ],
  "license": "MIT",
  "author": "Scavio <support@scavio.dev>",
  "homepage": "https://scavio.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/scavio-ai/scavio-js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
